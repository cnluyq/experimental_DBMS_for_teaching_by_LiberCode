    txn_mgr = TransactionManager(wal_manager=MockWAL())
    tid1 = txn_mgr.begin("test1")
    tid2 = txn_mgr.begin("test2")
    
    print(f"T1 state: {txn_mgr.get_transaction_state(tid1)}")
