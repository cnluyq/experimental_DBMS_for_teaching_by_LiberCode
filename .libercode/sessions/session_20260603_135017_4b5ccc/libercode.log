            for child in internal.children:
                child_page_id = getattr(child, 'page_id', 0)
                struct.pack_into('I', data, offset, child_page_id)
                offset += 4
        
        # 填充剩余空间
        # offset 应该是 <= PAGE_SIZE
        return bytes(data)
    
