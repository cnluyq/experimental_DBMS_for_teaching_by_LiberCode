    """
    简化的数据库类，用于测试
    
    提供execute方法，支持基本SQL操作。
    """
    
    def __init__(self, storage, buffer_pool, wal, executor):
        self.storage = storage
        self.buffer_pool = buffer_pool
        self.wal = wal
        self.executor = executor
        self._initialized = True
    
    def execute(self, sql: str):
        """执行SQL语句"""
        # 使用解析器解析
        from parser.parser import SQLParser
        parser = SQLParser()
        ast = parser.parse(sql)
        
        # 使用执行器执行
        return self.executor.execute(ast)
    
    @property
    def executor(self):
        return self._executor
    
    @executor.setter
