BEGIN = 0
    UPDATE = 1
    COMMIT = 2
    ROLLBACK = 3
    CHECKPOINT = 4

class LogRecord:
    HEADER_FMT = '<QQII'  # LSN(8) Prev(8) TxnID(4) Type(1) Len(4)
    HEADER_SIZE = struct.calcsize(HEADER_FMT)

    def __init__(self, lsn, prev_lsn, txn_id, type, payload=b''):
        self.lsn = lsn
        self.prev_lsn = prev_lsn
        self.txn_id = txn_id
        self.type = type
        self.payload = payload

    def serialize(self) -> bytes:
        header = struct.pack(
            self.HEADER_FMT,
            self.lsn,
            self.prev_lsn,
            self.txn_id,
            self.type,
            len(self.payload)
        )
        return header + self.payload

    @classmethod
    def deserialize(cls, data: bytes):
        header = struct.unpack(cls.HEADER_FMT, data[:cls.HEADER_SIZE])
        lsn, prev_lsn, txn_id, type, length = header
        payload = data[cls.HEADER_SIZE:cls.HEADER_SIZE+length]
        return cls(lsn, prev_lsn, txn_id, type, payload)
```

