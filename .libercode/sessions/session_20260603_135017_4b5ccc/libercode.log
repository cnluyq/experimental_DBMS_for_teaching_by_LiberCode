#!/usr/bin/env python3
"""
测试SQL解析器与执行引擎在主程序中的集成
"""

import sys
sys.path.insert(0, 'src')

from integration.coordinator import create_database
from integration.config import DatabaseConfig

def test_full_integration():
    """完整集成测试"""
    print("="*60)
    print("SQL解析器-执行引擎集成测试")
    print("="*60)

    # 配置：使用内存存储，无WAL，快速测试
    config = DatabaseConfig(
        storage_type='memory',
        wal_enabled=False,
        buffer_pool_size=10,
        autocommit=True,
        log_level='WARNING'
    )

    # 创建数据库实例
    db = create_database(config)
    print("✅ 数据库实例创建成功")

    # 测试1: CREATE TABLE
    sql = """
        CREATE TABLE users (
            id INT PRIMARY KEY,
            name TEXT NOT NULL,
            age INT,
            salary FLOAT
        );
    """
    result = db.execute(sql)
    print(f"✅ CREATE TABLE: {result.message}")
    assert result.success

    # 测试2: INSERT
    inserts = [
        "INSERT INTO users VALUES (1, 'Alice', 25, 50000.0);",
        "INSERT INTO users VALUES (2, 'Bob', 30, 60000.0);",
        "INSERT INTO users VALUES (3, 'Charlie', 35, 75000.0);",
    ]
    for sql in inserts:
        result = db.execute(sql)
        assert result.success and result.rows_affected == 1
    print(f"✅ 插入 {len(inserts)} 条记录成功")

    # 测试3: SELECT *
    result = db.execute("SELECT * FROM users;")
    assert len(result.rows) == 3
    print(f"✅ SELECT *: 返回 {len(result.rows)} 行")

    # 测试4: SELECT 投影
    result = db.execute("SELECT name, salary FROM users;")
    assert result.columns == ['name', 'salary']
    assert len(result.rows) == 3
    print(f"✅ 投影查询: {result.columns}")

    # 测试5: SELECT WHERE
    result = db.execute("SELECT * FROM users WHERE age > 25;")
    assert len(result.rows) == 2
    for row in result.rows:
        assert row['age'] > 25
    print(f"✅ WHERE过滤: 返回 {len(result.rows)} 行")

    # 测试6: UPDATE
    result = db.execute("UPDATE users SET salary = 65000.0 WHERE name = 'Bob';")
    assert result.success and result.rows_affected == 1
    print(f"✅ UPDATE: 影响 {result.rows_affected} 行")

    # 验证更新
    result = db.execute("SELECT salary FROM users WHERE name = 'Bob';")
    assert result.rows[0]['salary'] == 65000.0
    print("✅ UPDATE数据正确")

    # 测试7: DELETE
    result = db.execute("DELETE FROM users WHERE age < 30;")
    assert result.success and result.rows_affected == 1
    print(f"✅ DELETE: 影响 {result.rows_affected} 行")

    # 验证剩余记录
    result = db.execute("SELECT COUNT(*) FROM users;")
    assert len(result.rows) == 1
    print(f"✅ 剩余 {result.rows[0]['COUNT(*)']} 条记录")

    # 测试8: 复杂条件 AND/OR
    result = db.execute("""
        SELECT * FROM users
        WHERE age >= 30 OR salary > 50000;
    """)
    assert len(result.rows) >= 1
    print(f"✅ 复杂OR条件查询: 返回 {len(result.rows)} 行")

    # 测试9: 事务
    db.begin_transaction()
    db.execute("INSERT INTO users VALUES (4, 'David', 28, 45000.0);")
    # 在事务内查询
    result = db.execute("SELECT COUNT(*) FROM users;")
    count_in_tx = result.rows[0]['COUNT(*)']
    db.commit()
    print(f"✅ 事务提交后记录数: {count_in_tx}")

    # 测试10: DROP TABLE
    result = db.execute("DROP TABLE users;")
    assert result.success
    print("✅ DROP TABLE 成功")

    # 优雅关闭
    db.shutdown()
    print("✅ 数据库关闭完成")

    print("="*60)
    print("🎉 集成测试全部通过!")
    print("="*60)
    return True

if __name__ == '__main__':
    try:
        test_full_integration()
        sys.exit(0)
    except Exception as e:
        print(f"\n❌ 测试失败: {e}")
        import traceback
        traceback.print_exc()
        sys.exit(1)
