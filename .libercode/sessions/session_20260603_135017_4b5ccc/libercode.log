        return f"IndexEntry(key={self.key}, value={self.value})"
    
    def __eq__(self, other) -> bool:
        if not isinstance(other, IndexEntry):
            return False
        return self.key == other.key and self.value == other.value
    
    def __hash__(self) -> int:
