./.libercode/sessions/session_20260603_135017_4b5ccc/libercode.log:17815:        "new_text": "    def recover_from_wal(self, wal_manager):\n        \"\"\"\n        从WAL恢复数据库状态\n        \n        根据WAL日志重做已提交事务，撤销未提交事务\n        \n        Args:\n            wal_manager: WALManager实例（必须是已打开的）\n        \"\"\"\n        if not wal_manager:\n            return\n        \n        print(\"\\n\" + \"=\"*60)\n        print(\"SimpleStorage: 执行WAL恢复...\")\n        print(\"=\"*60)\n        \n        # 分析WAL文件\n        analysis = wal_manager.analyze_recovery()\n        \n        if analysis['status'] == 'fresh':\n            print(\"ℹ️  无WAL文件，跳过恢复\")\n            return\n        \n        logs = analysis['logs']\n        active_tids = set(analysis['active_transactions'])\n        \n        print(f\"📋 恢复分析: total_logs={len(logs)}, active_txns={len(active_tids)}\")\n        \n        # 阶段1: 重做(Redo) - 重放所有数据修改日志（幂等）\n        redo_count = 0\n        for log in logs:\n            if log.type.name in ('UPDATE', 'INSERT', 'DELETE'):\n                # 需要重做所有数据修改，因为它们都是幂等的\n                if self._apply_log_to_storage(log):\n                    redo_count += 1\n        \n        print(f\"✅ Redo阶段: 应用了 {redo_count} 条日志\")\n        \n        # 阶段2: 撤销(Undo) - 回滚未提交事务\n        undo_count = 0\n        # 按LSN逆序处理需要撤销的日志\n        logs_to_undo = [log for log in logs if log.tid in active_tids and log.type.name in ('UPDATE', 'INSERT', 'DELETE')]\n        logs_to_undo.sort(key=lambda x: x.lsn, reverse=True)\n        \n        for log in logs_to_undo:\n            if self._undo_log_in_storage(log):\n                undo_count += 1\n        \n        print(f\"✅ Undo阶段: 回滚了 {undo_count} 条日志\")\n        \n        # 可能需要刷新缓存\n        if hasattr(self.storage, 'flush_all_dirty'):\n            self.storage.flush_all_dirty()\n        \n        print(\"=\"*60)\n        print(\"🎯 SimpleStorage恢复完成\")\n        print(\"=\"*60)\n    \n    def _apply_log_to_storage(self, log):\n        \"\"\"将日志应用到存储（重做）\"\"\"\n        try:\n            import struct\n            from core.wal import LogType\n            \n            if log.type == LogType.UPDATE:\n                # UPDATE payload: page_id(4), offset(4), old_len(2), new_len(2), old_value, new_value\n                page_id, offset, old_len, new_len = struct.unpack('I I H H', log.payload[:12])\n                new_value = log.payload[12+old_len:12+old_len+new_len]\n                \n                # 读取页面，应用修改\n                page_data = self.storage.page_read(page_id)\n                if page_data is None:\n                    return False\n                \n                # 修改数据\n                page_array = bytearray(page_data)\n                page_array[offset:offset+len(new_value)] = new_value\n                self.storage.page_write(page_id, bytes(page_array))\n                return True\n            \n            elif log.type == LogType.INSERT:\n                # INSERT payload: page_id(4), offset(4), length(2), data\n                page_id, offset, length = struct.unpack('I I H', log.payload[:10])\n                data = log.payload[10:10+length]\n                \n                page_data = self.storage.page_read(page_id)\n                if page_data is None:\n                    # 页可能不存在，在WAL中不应该发生，跳过\n                    return False\n                \n                page_array = bytearray(page_data)\n                page_array[offset:offset+len(data)] = data\n                self.storage.page_write(page_id, bytes(page_array))\n                return True\n            \n            elif log.type == LogType.DELETE:\n                # DELETE payload: page_id(4), offset(4), old_len(2), old_data\n                page_id, offset, old_len = struct.unpack('I I H', log.payload[:10])\n                \n                page_data = self.storage.page_read(page_id)\n                if page_data is None:\n                    return False\n                \n                page_array = bytearray(page_data)\n                page_array[offset:offset+old_len] = b'\\x00' * old_len\n                self.storage.page_write(page_id, bytes(page_array))\n                return True\n            \n            return False\n        except Exception as e:\n            print(f\"⚠️  应用日志LSN={log.lsn}失败: {e}\")\n            return False\n    \n    def _undo_log_in_storage(self, log):\n        \"\"\"撤销日志（回滚）\"\"\"\n        try:\n            import struct\n            from core.wal import LogType\n            \n            if log.type == LogType.UPDATE:\n                # UPDATE payload: page_id(4), offset(4), old_len(2), new_len(2), old_value, new_value\n                page_id, offset, old_len, new_len = struct.unpack('I I H H', log.payload[:12])\n                old_value = log.payload[12:12+old_len]\n                \n                page_data = self.storage.page_read(page_id)\n                if page_data is None:\n                    return False\n                \n                page_array = bytearray(page_data)\n                page_array[offset:offset+len(old_value)] = old_value\n                self.storage.page_write(page_id, bytes(page_array))\n                return True\n            \n            elif log.type == LogType.INSERT:\n                # INSERT需要undo: 清零插入的区域\n                page_id, offset, length = struct.unpack('I I H', log.payload[:10])\n                \n                page_data = self.storage.page_read(page_id)\n                if page_data is None:\n                    return False\n                \n                page_array = bytearray(page_data)\n                page_array[offset:offset+length] = b'\\x00' * length\n                self.storage.page_write(page_id, bytes(page_array))\n                return True\n            \n            elif log.type == LogType.DELETE:\n                # DELETE需要undo: 恢复旧数据\n                page_id, offset, old_len = struct.unpack('I I H', log.payload[:10])\n                old_data = log.payload[10:10+old_len]\n                \n                page_data = self.storage.page_read(page_id)\n                if page_data is None:\n                    return False\n                \n                page_array = bytearray(page_data)\n                page_array[offset:offset+len(old_data)] = old_data\n                self.storage.page_write(page_id, bytes(page_array))\n                return True\n            \n            return False\n        except Exception as e:\n            print(f\"⚠️  撤销日志LSN={log.lsn}失败: {e}\")\n            return False"
