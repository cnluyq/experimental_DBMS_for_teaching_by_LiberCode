### 序列化示例（Python）

```python
import struct
from enum import IntEnum

class LogType(IntEnum):
    BEGIN = 0
    UPDATE = 1
    COMMIT = 2
    ROLLBACK = 3
    CHECKPOINT = 4

class LogRecord:
    """日志记录类"""
    # 实际代码中的格式：LSN(8), TxnID(4), Type(1), Size(4), PrevLSN(8) = 25 bytes
    HEADER_FORMAT = 'QIBBQ'  # Q=uint64, I=uint32, B=uint8, B=uint8, Q=uint64

    def __init__(self, lsn, txn_id, log_type, payload=b'', prev_lsn=0):
        self.lsn = lsn          # 日志序列号
        self.txn_id = txn_id    # 事务ID
        self.type = log_type    # LogType枚举
        self.payload = payload  # 变长数据
        self.prev_lsn = prev_lsn  # 同事务上一条LSN

    def serialize(self) -> bytes:
        """序列化日志记录"""
        header = struct.pack(
            self.HEADER_FORMAT,
            self.lsn,
            self.txn_id,
            int(self.type),
            len(self.payload),
            self.prev_lsn
        )
        return header + self.payload

    @classmethod
    def deserialize(cls, data: bytes):
        """从字节流反序列化"""
        if len(data) < 25:
            raise ValueError("Data too short for log record")
        lsn, tid, log_type_int, size, prev_lsn = struct.unpack(
            cls.HEADER_FORMAT, data[:25])
        return cls(
            lsn=lsn,
            txn_id=tid,
            log_type=LogType(log_type_int),
            payload=data[25:25+size],
            prev_lsn=prev_lsn
        )
```
