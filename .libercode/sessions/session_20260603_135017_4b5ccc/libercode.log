#!/usr/bin/env python3
"""
ProjoDB - 实验性教学数据库管理系统
主入口点

支持两种运行模式：
1. REPL交互模式（默认）：python main.py
2. 单条SQL执行：python main.py -e "SQL statement"
"""

import argparse
import sys
import signal
from typing import Optional

from integration.config import DatabaseConfig
from integration.coordinator import create_database
from cli.repl import REPL


def signal_handler(signum, frame):
    """处理系统信号"""
    print("\nReceived interrupt signal, shutting down...")
    sys.exit(0)


def run_repl(config: DatabaseConfig):
    """启动REPL交互模式"""
    # 设置信号处理
    signal.signal(signal.SIGINT, signal_handler)
    signal.signal(signal.SIGTERM, signal_handler)
    
    try:
        # 创建数据库实例
        db = create_database(config)
        
        # 启动REPL
        repl = REPL(db)
        repl.start()
        
    except KeyboardInterrupt:
        print("\nInterrupted by user.")
        sys.exit(0)
    except Exception as e:
        print(f"Fatal error: {e}")
        sys.exit(1)


def run_single_sql(config: DatabaseConfig, sql: str):
    """执行单条SQL语句"""
    try:
        db = create_database(config)
        result = db.execute(sql)
        
        # 打印结果
        if hasattr(result, 'rows'):
            rows = result.rows or []
            columns = result.columns or []
            
            if rows:
                # 打印列头（CSV格式）
                col_names = [str(col) for col in columns]
                print(','.join(col_names))
                
                for row in rows:
                    values = [str(row.get(col, '')) for col in columns]
                    print(','.join(values))
            else:
                print("No rows returned.")
            
            if hasattr(result, 'rows_affected') and result.rows_affected:
                print(f"Rows affected: {result.rows_affected}")
        else:
            print(f"Result: {result}")
        
        db.shutdown()
        
    except Exception as e:
        print(f"Error: {e}")
        sys.exit(1)


def parse_args():
    """解析命令行参数"""
    parser = argparse.ArgumentParser(
        description="ProjoDB - Experimental Educational Database"
    )
    
    parser.add_argument(
        '-c', '--config',
        help='Path to configuration file (JSON)',
        default=None
    )
    
    parser.add_argument(
        '-e', '--execute',
        help='Execute a single SQL statement and exit',
        default=None
    )
    
    parser.add_argument(
        '--data-dir',
        help='Data directory path',
        default='./data'
    )
    
    parser.add_argument(
        '--no-wal',
        help='Disable WAL logging',
        action='store_true'
    )
    
    parser.add_argument(
        '--autocommit',
        help='Enable autocommit mode',
        action='store_true'
    )
    
    parser.add_argument(
        '--buffer-size',
        help='Buffer pool size (number of frames)',
        type=int,
        default=64
    )
    
    parser.add_argument(
        '--page-size',
        help='Page size in bytes',
        type=int,
        default=4096
    )
    
    parser.add_argument(
        '--log-level',
        help='Logging level',
        choices=['DEBUG', 'INFO', 'WARNING', 'ERROR'],
        default='INFO'
    )
    
    return parser.parse_args()


def main():
    """主入口"""
    args = parse_args()
    
    # 加载配置
    if args.config:
        config = DatabaseConfig.from_file(args.config)
    else:
        config = DatabaseConfig()
    
    # 覆盖配置（命令行优先级最高）
    config.data_dir = args.data_dir
    config.wal_enabled = not args.no_wal
    config.autocommit = args.autocommit
    config.buffer_pool_size = args.buffer_size
    config.page_size = args.page_size
    config.log_level = args.log_level
    
    # 选择运行模式
    if args.execute:
        run_single_sql(config, args.execute)
    else:
        run_repl(config)


if __name__ == '__main__':
    main()
